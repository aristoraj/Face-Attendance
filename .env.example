# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env for local development
# NEVER commit .env to git (it's in .gitignore)
# On Render, set these in the dashboard under Environment → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── HOW TO GET ZOHO OAUTH CREDENTIALS ─────────────────────────────────────────
# 1. Go to https://api-console.zoho.com
# 2. Create a "Self Client" application
# 3. Scopes needed:
#      ZohoCreator.report.READ
#      ZohoCreator.form.CREATE
# 4. Generate code with those scopes (one-time)
# 5. Exchange code for refresh_token via Postman or curl
#    POST https://accounts.zoho.com/oauth/v2/token
#      grant_type=authorization_code
#      client_id=YOUR_CLIENT_ID
#      client_secret=YOUR_CLIENT_SECRET
#      redirect_uri=https://www.zoho.com (or your redirect)
#      code=THE_CODE_FROM_STEP_4
# ─────────────────────────────────────────────────────────────────────────────

# Zoho OAuth 2.0 Credentials
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here

# Zoho Creator App Config
# ZOHO_ACCOUNT_OWNER: your Zoho account username (shown in Creator URL)
# Example: if your app URL is creator.zoho.com/aristo/student_management → "aristo"
ZOHO_ACCOUNT_OWNER=your_zoho_username
ZOHO_APP_NAME=student_management
ZOHO_STUDENT_REPORT=All_Students
ZOHO_ATTENDANCE_FORM=Attendance

# Data center: com | eu | in | com.au | jp
ZOHO_DATA_CENTER=com

# ── Field Names (link names from Zoho Creator, NOT display names) ──────────────
# To find link names: Creator → Form → Settings → "Link name" column
FIELD_STUDENT_ID=Student_ID
FIELD_STUDENT_NAME=Name
FIELD_STUDENT_PHOTO=Photo
FIELD_STUDENT_ROLL=Roll_Number
FIELD_STUDENT_CLASS=Class

FIELD_ATT_STUDENT_ID=Student_ID
FIELD_ATT_STUDENT_NAME=Student_Name
FIELD_ATT_DATE=Date
FIELD_ATT_TIME=Time
FIELD_ATT_STATUS=Status
FIELD_ATT_VERIFICATION=Verification_Type

# ── Face Recognition Settings ──────────────────────────────────────────────────
# Tolerance: how similar faces must be. Lower = stricter.
# 0.4 = very strict, 0.55 = balanced, 0.65 = lenient
FACE_MATCH_TOLERANCE=0.55

# How long to cache student encodings (seconds). 3600 = 1 hour.
CACHE_TTL_SECONDS=3600

# ── App Settings ───────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secure_string
DEBUG=false
PORT=5000
